# PrivaTools backend env template.
#
# Copy to /opt/privatool/.env on the VM and edit. NEVER commit a real
# .env — the .gitignore already ignores .env, this file is the only
# place env keys should live in git.
#
# The systemd unit (deploy/privatool-backend.service) loads this file
# with EnvironmentFile=-/opt/privatool/.env (leading - means "missing
# file is OK", but in production you want it present).

# --- Application ----------------------------------------------------------
APP_VERSION=1.5.2
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Network --------------------------------------------------------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Comma-separated hostnames the backend will accept. The TrustedHost
# middleware uses this to reject Host-header spoofing — must match the
# domain(s) nginx routes to us under.
TRUSTED_HOSTS=privatools.com,www.privatools.com

# CORS origin allow-list. No wildcards in production.
ALLOWED_ORIGINS=https://privatools.com,https://www.privatools.com

# --- Uploads --------------------------------------------------------------
# 100 MB. Note: the app actually reads MAX_UPLOAD_MB (megabytes) — kept
# the byte form here for documentation/clarity. nginx is set to 110m to
# accommodate multipart overhead.
MAX_UPLOAD_BYTES=104857600
MAX_UPLOAD_MB=100

# --- Rate limiting --------------------------------------------------------
RATE_LIMIT=30/minute

# --- Tesseract OCR --------------------------------------------------------
# Ubuntu 22.04 / 24.04 ship this path with the tesseract-ocr package.
TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata/

# --- Temp dir + janitor ---------------------------------------------------
# Where uploads land before processing. Must be on a writable mount —
# systemd's ProtectSystem=strict allows /opt/privatool/tmp via
# ReadWritePaths. Janitor sweeps every 5 min, drops files older than 10 min.
TEMP_DIR=/opt/privatool/tmp
CLEANUP_INTERVAL_SECONDS=300
TEMP_MAX_AGE_SECONDS=600

# --- Timeouts -------------------------------------------------------------
REQUEST_TIMEOUT_SECONDS=120
